# Copia este archivo como .env y pon tus claves reales

# Imágenes/videos de stock — gratis en https://www.pexels.com/api/
PEXELS_API_KEY=tu_clave_aqui

# (Premium, opcional) Guiones con Claude — https://platform.claude.com
# Sin esta clave, los guiones se generan con un servicio gratuito.
# ANTHROPIC_API_KEY=sk-ant-...

# (Premium, opcional) Voz y video con IA usando tus créditos de MiniMax
# En minimax.io → API Keys. El Group ID aparece en tu perfil/cuenta.
# MINIMAX_API_KEY=...
# MINIMAX_GROUP_ID=...
# Opcionales (valores por defecto):
# MINIMAX_TTS_MODEL=speech-02-hd
# MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-02
# MINIMAX_BASE_URL=https://api.minimax.io
